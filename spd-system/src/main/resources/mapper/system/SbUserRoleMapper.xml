<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spd.system.mapper.SbUserRoleMapper">

  <resultMap type="com.spd.system.domain.SbUserRole" id="SbUserRoleResult">
    <result property="userId" column="user_id"/>
    <result property="roleId" column="role_id"/>
    <result property="customerId" column="customer_id"/>
    <result property="deleteBy" column="delete_by"/>
    <result property="deleteTime" column="delete_time"/>
  </resultMap>

  <delete id="deleteSbUserRoleByUserId" parameterType="Long">
    delete from sb_user_role where user_id = #{userId}
  </delete>

  <select id="countSbUserRoleByRoleId" parameterType="String" resultType="Integer">
    select count(1) from sb_user_role where role_id = #{roleId}
  </select>

  <delete id="deleteSbUserRole" parameterType="Long">
    delete from sb_user_role where user_id in
    <foreach collection="array" item="userId" open="(" separator="," close=")">
      #{userId}
    </foreach>
  </delete>

  <insert id="batchSbUserRole">
    insert into sb_user_role(user_id, role_id, customer_id) values
    <foreach item="item" index="index" collection="list" separator=",">
      (#{item.userId}, #{item.roleId}, #{item.customerId})
    </foreach>
  </insert>

  <delete id="deleteSbUserRoleInfo" parameterType="com.spd.system.domain.SbUserRole">
    delete from sb_user_role where user_id = #{userId} and role_id = #{roleId}
  </delete>

</mapper>

