<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spd.system.mapper.SbRoleMenuMapper">

  <resultMap type="com.spd.system.domain.SbRoleMenu" id="SbRoleMenuResult">
    <result property="roleId" column="role_id"/>
    <result property="menuId" column="menu_id"/>
    <result property="customerId" column="customer_id"/>
    <result property="deleteBy" column="delete_by"/>
    <result property="deleteTime" column="delete_time"/>
  </resultMap>

  <select id="checkSbMenuExistRole" resultType="Integer">
    select count(1) from sb_role_menu where menu_id = #{menuId}
  </select>

  <delete id="deleteSbRoleMenuByRoleId" parameterType="String">
    delete from sb_role_menu where role_id = #{roleId}
  </delete>

  <delete id="deleteSbRoleMenu" parameterType="String">
    delete from sb_role_menu where role_id in
    <foreach collection="array" item="roleId" open="(" separator="," close=")">
      #{roleId}
    </foreach>
  </delete>

  <insert id="batchSbRoleMenu">
    insert into sb_role_menu(role_id, menu_id, customer_id) values
    <foreach item="item" index="index" collection="list" separator=",">
      (#{item.roleId}, #{item.menuId}, #{item.customerId})
    </foreach>
  </insert>

</mapper>

