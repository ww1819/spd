<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spd.department.mapper.BasApplyTemplateMapper">

    <resultMap type="com.spd.department.domain.BasApplyTemplate" id="BasApplyTemplateResult">
        <id property="id" column="id"/>
        <result property="templateName" column="template_name"/>
        <result property="warehouseId" column="warehouse_id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/>
        <result property="deleteBy" column="delete_by"/>
        <result property="deleteTime" column="delete_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <association property="warehouse" column="warehouse_id" javaType="com.spd.foundation.domain.FdWarehouse" resultMap="warehouseResult"/>
    </resultMap>

    <resultMap id="warehouseResult" type="com.spd.foundation.domain.FdWarehouse">
        <id property="id" column="wId"/>
        <result property="name" column="warehouseName"/>
    </resultMap>

    <resultMap type="com.spd.department.domain.BasApplyTemplateEntry" id="BasApplyTemplateEntryResult">
        <id property="id" column="entry_id"/>
        <result property="parenId" column="entry_paren_id"/>
        <result property="materialId" column="entry_material_id"/>
        <result property="qty" column="entry_qty"/>
        <result property="sortOrder" column="entry_sort_order"/>
        <association property="material" column="entry_material_id" javaType="com.spd.foundation.domain.FdMaterial" resultMap="templateMaterialResult"/>
    </resultMap>

    <resultMap id="templateMaterialResult" type="com.spd.foundation.domain.FdMaterial">
        <id property="id" column="entry_material_id"/>
        <result property="code" column="material_code"/>
        <result property="name" column="material_name"/>
        <result property="speci" column="material_speci"/>
        <result property="model" column="material_model"/>
        <result property="price" column="material_price"/>
        <result property="registerNo" column="material_register_no"/>
        <result property="periodDate" column="material_period_date"/>
        <association property="fdUnit" javaType="com.spd.foundation.domain.FdUnit" resultMap="templateFdUnitResult"/>
        <association property="fdFactory" javaType="com.spd.foundation.domain.FdFactory" resultMap="templateFdFactoryResult"/>
        <association property="supplier" javaType="com.spd.foundation.domain.FdSupplier" resultMap="templateSupplierResult"/>
        <association property="fdWarehouseCategory" javaType="com.spd.foundation.domain.FdWarehouseCategory" resultMap="templateWarehouseCategoryResult"/>
        <association property="fdFinanceCategory" javaType="com.spd.foundation.domain.FdFinanceCategory" resultMap="templateFinanceCategoryResult"/>
    </resultMap>
    <resultMap id="templateFdUnitResult" type="com.spd.foundation.domain.FdUnit">
        <result property="unitId" column="mat_unit_id"/>
        <result property="unitName" column="mat_unit_name"/>
    </resultMap>
    <resultMap id="templateFdFactoryResult" type="com.spd.foundation.domain.FdFactory">
        <result property="factoryId" column="mat_factory_id"/>
        <result property="factoryName" column="mat_factory_name"/>
    </resultMap>
    <resultMap id="templateSupplierResult" type="com.spd.foundation.domain.FdSupplier">
        <result property="id" column="mat_supplier_id"/>
        <result property="name" column="mat_supplier_name"/>
    </resultMap>
    <resultMap id="templateWarehouseCategoryResult" type="com.spd.foundation.domain.FdWarehouseCategory">
        <result property="warehouseCategoryId" column="mat_warehouse_id"/>
        <result property="warehouseCategoryName" column="mat_warehouse_name"/>
    </resultMap>
    <resultMap id="templateFinanceCategoryResult" type="com.spd.foundation.domain.FdFinanceCategory">
        <result property="financeCategoryId" column="mat_finance_id"/>
        <result property="financeCategoryName" column="mat_finance_name"/>
    </resultMap>

    <resultMap type="com.spd.department.domain.BasApplyTemplate" id="BasApplyTemplateWithEntryResult" extends="BasApplyTemplateResult">
        <collection property="entryList" column="id" ofType="com.spd.department.domain.BasApplyTemplateEntry" resultMap="BasApplyTemplateEntryResult" notNullColumn="entry_id"/>
    </resultMap>

    <sql id="selectTemplateVo">
        select id, template_name, warehouse_id, tenant_id, remark, del_flag, create_by, create_time, update_by, update_time, delete_by, delete_time
        from bas_apply_template
    </sql>

    <select id="selectBasApplyTemplateList" resultMap="BasApplyTemplateResult">
        select t.id, t.template_name, t.warehouse_id, t.tenant_id, t.remark, t.del_flag, t.delete_by, t.delete_time, t.create_by, t.create_time, t.update_by, t.update_time,
               w.id as wId, w.name as warehouseName
        from bas_apply_template t
        left join fd_warehouse w on t.warehouse_id = w.id
        <where>
            and (t.del_flag = 0 or t.del_flag is null)
            <if test="tenantId != null and tenantId != ''">and (t.tenant_id = #{tenantId})</if>
            <if test="templateName != null and templateName != ''">and t.template_name like concat('%', #{templateName}, '%')</if>
        </where>
        order by t.create_time desc
    </select>

    <select id="selectBasApplyTemplateById" resultMap="BasApplyTemplateWithEntryResult">
        select t.id, t.template_name, t.warehouse_id, t.tenant_id, t.remark, t.del_flag, t.delete_by, t.delete_time, t.create_by, t.create_time, t.update_by, t.update_time,
               w.id as wId, w.name as warehouseName,
               e.id as entry_id, e.paren_id as entry_paren_id, e.material_id as entry_material_id, e.qty as entry_qty, e.sort_order as entry_sort_order,
               m.code as material_code, m.name as material_name, m.speci as material_speci, m.model as material_model, m.price as material_price,
               m.register_no as material_register_no, m.period_date as material_period_date,
               u.unit_id as mat_unit_id, u.unit_name as mat_unit_name,
               f.factory_id as mat_factory_id, f.factory_name as mat_factory_name,
               s.id as mat_supplier_id, s.name as mat_supplier_name,
               wc.warehouse_category_id as mat_warehouse_id, wc.warehouse_category_name as mat_warehouse_name,
               fc.finance_category_id as mat_finance_id, fc.finance_category_name as mat_finance_name
        from bas_apply_template t
        left join fd_warehouse w on t.warehouse_id = w.id
        left join bas_apply_template_entry e on e.paren_id = t.id and (e.delete_time is null)
        left join fd_material m on e.material_id = m.id
        left join fd_unit u on m.unit_id = u.unit_id
        left join fd_factory f on m.factory_id = f.factory_id
        left join fd_supplier s on m.supplier_id = s.id
        left join fd_warehouse_category wc on m.storeroom_id = wc.warehouse_category_id
        left join fd_finance_category fc on m.finance_category_id = fc.finance_category_id
        where t.id = #{id}
    </select>

    <insert id="insertBasApplyTemplate" parameterType="com.spd.department.domain.BasApplyTemplate" useGeneratedKeys="true" keyProperty="id">
        insert into bas_apply_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="templateName != null and templateName != ''">template_name,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="tenantId != null">tenant_id,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="templateName != null and templateName != ''">#{templateName},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="tenantId != null">#{tenantId},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateBasApplyTemplate" parameterType="com.spd.department.domain.BasApplyTemplate">
        update bas_apply_template
        <trim prefix="SET" suffixOverrides=",">
            <if test="templateName != null and templateName != ''">template_name = #{templateName},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="tenantId != null">tenant_id = #{tenantId},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="deleteBasApplyTemplateById">
        update bas_apply_template set del_flag = 1, delete_by = #{deleteBy}, delete_time = now(), update_time = now() where id = #{id}
    </update>

    <!-- 逻辑删除：表有 delete_by、delete_time，使用更新代替物理删除 -->
    <update id="deleteEntryByParenId">
        update bas_apply_template_entry set delete_by = #{deleteBy}, delete_time = now() where paren_id = #{parenId} and (delete_time is null)
    </update>

    <insert id="batchInsertEntry">
        insert into bas_apply_template_entry(paren_id, material_id, qty, sort_order) values
        <foreach item="item" collection="list" separator=",">
            (#{item.parenId}, #{item.materialId}, #{item.qty}, #{item.sortOrder})
        </foreach>
    </insert>
</mapper>
