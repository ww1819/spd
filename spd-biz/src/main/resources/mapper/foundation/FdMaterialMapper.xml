    <sql id="selectFdMaterialVo">
        select m.id, m.code m_code, m.name m_name, m.supplier_id , m.speci, m.model,
            m.price, m.default_warehouse_id as default_warehouse_id, m.create_by, m.create_time, m.update_by, m.update_time, m.delete_by, m.delete_time, m.tenant_id, m.del_flag,
            m.referred_name, m.use_name, m.factory_id, m.storeroom_id, m.material_category_id, m.finance_category_id, m.unit_id,
            m.his_id, m.his_spec_packing_id,
            m.his_charge_item_id,
            hci.item_code as his_charge_item_code,
            hci.item_name as his_charge_item_name,
            hci.spec_model as his_charge_item_speci,
            hci.unit as his_charge_item_unit,
            hci.price as his_charge_item_price,
            m.register_name, m.register_no, m.medical_name, m.medical_no, m.period_date, m.successful_type,
            m.successful_no, m.successful_price, m.sale_price, m.package_speci, m.min_package_qty, m.producer, m.material_level,
            m.register_level, m.risk_level, m.firstaid_level, m.doctor_level, m.brand, m.useto, m.quality,
            m.function, m.is_way, m.udi_no, m.permit_no, m.country_no, m.country_name, m.description,
            m.is_use, m.is_procure, m.is_monitor, m.is_gz,
			<!-- 如果报错 Unknown column 'm.is_follow'，请先执行 SQL: ALTER TABLE fd_material ADD COLUMN is_follow varchar(1) NULL COMMENT '是否跟台（1=是，2=否）' AFTER is_gz; -->
            m.is_follow,
            <!-- 如果报错 Unknown column 'm.is_billing'，请先执行 SQL: ALTER TABLE fd_material ADD COLUMN is_billing char(4) NULL COMMENT '是否计费：1=计费,2=不计费' AFTER is_follow; -->
            m.is_billing,
            m.is_temporary_purchase,
            m.is_service_fee,
            m.is_sunshine_procurement,
            m.sunshine_code,
			<!-- 如果报错 Unknown column 'm.location_id'，请先执行 SQL: ALTER TABLE fd_material ADD COLUMN location_id bigint(20) NULL COMMENT '货位ID' AFTER is_follow; -->
			m.location_id,
            m.selection_reason,
            s.id sid, s.code supplier_code,s.name supplier_name,
            w.warehouse_category_id wid, w.warehouse_category_code w_code,w.warehouse_category_name w_name,
            f.factory_id fid,f.factory_code f_code,f.factory_name f_name,
            u.unit_id uid,u.unit_code u_code,u.unit_name u_name,cwfl.finance_category_code cwfl_code,cwfl.finance_category_name cwfl_name,
            mc.material_category_id mcid, mc.material_category_code mc_code, mc.material_category_name mc_name,
            l.location_id lid, l.location_name l_name
        from fd_material m
        left join fd_supplier s on m.supplier_id = s.id
        left join fd_warehouse_category w on m.storeroom_id = w.warehouse_category_id
        left join fd_factory f on m.factory_id = f.factory_id
        left join fd_unit u on u.unit_id = m.unit_id
        left join fd_finance_category cwfl on m.finance_category_id = cwfl.finance_category_id
        left join fd_material_category mc on m.material_category_id = mc.material_category_id
            and mc.tenant_id = m.tenant_id
            and (mc.del_flag is null or mc.del_flag != 1)
        left join fd_location l on m.location_id = l.location_id
        left join his_charge_item_mirror hci on hci.tenant_id = m.tenant_id
            and hci.charge_item_id = m.his_charge_item_id
            and (hci.deleted_flag is null or hci.deleted_flag != 1)
    </sql>

    <select id="selectFdMaterialList" parameterType="FdMaterial" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where m.del_flag != 1
        and m.tenant_id = #{scopedTenantId}
        <!-- 未指定使用状态时默认不展示已停用（is_use='2'）；档案页可按 isUse 筛选；includeDisabledInList 为内部全量查询 -->
        <choose>
            <when test="isUse != null and isUse != ''">
                and m.is_use = #{isUse}
            </when>
            <when test="includeDisabledInList != null and includeDisabledInList == true">
            </when>
            <otherwise>
                and (m.is_use is null or m.is_use = '' or m.is_use != '2')
            </otherwise>
        </choose>
        <if test="code != null  and code != ''"> and m.code like concat('%', #{code}, '%') escape '\\'</if>
        <if test="name != null  and name != ''"> and (
            m.code like concat('%', #{name}, '%') escape '\\'
            OR m.name like concat('%', #{name}, '%') escape '\\'
            OR m.referred_name like concat('%', #{name}, '%') escape '\\'
            OR ifnull(m.use_name, '') like concat('%', #{name}, '%') escape '\\'
            OR ifnull(m.brand, '') like concat('%', #{name}, '%') escape '\\'
            OR ifnull(m.speci, '') like concat('%', #{name}, '%') escape '\\'
            OR ifnull(m.model, '') like concat('%', #{name}, '%') escape '\\'
        )</if>
        <if test="nameSearch != null and nameSearch != ''"> and m.referred_name like concat('%', #{nameSearch}, '%')</if>
        <if test="speci != null and speci != ''"> and m.speci like concat('%', #{speci}, '%') escape '\\'</if>
        <if test="referredName != null and referredName != ''"> and m.referred_name like concat('%', #{referredName}, '%')</if>
        <if test="supplierId != null "> and m.supplier_id = #{supplierId}</if>
        <if test="id != null "> and m.id = #{id}</if>
        <if test="udiNo != null and udiNo != ''"> and ifnull(m.udi_no, '') like concat('%', #{udiNo}, '%') escape '\\'</if>
        <if test="factoryKeyword != null and factoryKeyword != ''"> and (
            ifnull(f.factory_code, '') like concat('%', #{factoryKeyword}, '%') escape '\\'
            OR ifnull(f.factory_name, '') like concat('%', #{factoryKeyword}, '%') escape '\\'
            OR ifnull(f.factory_referred_code, '') like concat('%', #{factoryKeyword}, '%') escape '\\'
        )</if>
        <if test="isGz != null and isGz != ''"> and m.is_gz = #{isGz}</if>
        <if test="isFollow != null and isFollow != ''"> and m.is_follow = #{isFollow}</if>
        <if test="isProcure != null and isProcure != ''"> and m.is_procure = #{isProcure}</if>
        <if test="registerNo != null and registerNo != ''"> and m.register_no like concat('%', #{registerNo}, '%')</if>
        <if test="sunshineCode != null and sunshineCode != ''"> and m.sunshine_code like concat('%', #{sunshineCode}, '%')</if>
        <if test="factoryId != null "> and m.factory_id = #{factoryId}</if>
        <if test="storeroomIds != null and storeroomIds.length > 0">
            and m.storeroom_id in
            <foreach collection="storeroomIds" item="sid" open="(" separator="," close=")">#{sid}</foreach>
        </if>
        <if test="(storeroomIds == null or storeroomIds.length == 0) and storeroomId != null">
            and m.storeroom_id = #{storeroomId}
        </if>
        <if test="materialCategoryIds != null and materialCategoryIds.length > 0">
            and m.material_category_id in
            <foreach collection="materialCategoryIds" item="mcid" open="(" separator="," close=")">#{mcid}</foreach>
        </if>
        <if test="(materialCategoryIds == null or materialCategoryIds.length == 0) and materialCategoryId != null and materialCategoryId != ''">
            and m.material_category_id = #{materialCategoryId}
        </if>
        <if test="warehouseId != null and (skipWarehouseFixedNumberExists == null or skipWarehouseFixedNumberExists != true)">
            and exists (
                select 1
                from wh_fixed_number fn
                where fn.material_id = m.id
                  and fn.warehouse_id = #{warehouseId}
                  and fn.del_flag != 1
                  and (fn.enable_status = '0' or fn.enable_status is null)
                  and fn.tenant_id = #{scopedTenantId}
            )
        </if>
        <if test="financeCategoryIds != null and financeCategoryIds.length > 0">
            and m.finance_category_id in
            <foreach collection="financeCategoryIds" item="fcid" open="(" separator="," close=")">#{fcid}</foreach>
        </if>
        <if test="(financeCategoryIds == null or financeCategoryIds.length == 0) and financeCategoryId != null">
            and m.finance_category_id = #{financeCategoryId}
        </if>
        <if test="locationId != null "> and m.location_id = #{locationId}</if>
        <if test="isBilling != null and isBilling != ''"> and m.is_billing = #{isBilling}</if>
        <if test="hisBindStatus != null and hisBindStatus != '' and (hisBindStatus == '1' or hisBindStatus == 1)">
            and m.his_charge_item_id is not null
            and m.his_charge_item_id != ''
        </if>
        <if test="hisBindStatus != null and hisBindStatus != '' and (hisBindStatus == '0' or hisBindStatus == 0)">
            and (m.his_charge_item_id is null or m.his_charge_item_id = '')
        </if>
        <if test="hisChargeItemId != null and hisChargeItemId != ''">
            and m.his_charge_item_id like concat('%', #{hisChargeItemId}, '%')
        </if>
        <if test="beginDate != null "> and m.create_time &gt;= #{beginDate}</if>
        <if test="endDate != null "> and m.create_time &lt;= #{endDate}</if>
        <if test="excludeMaterialIdList != null and excludeMaterialIdList.size() > 0"> and m.id not in <foreach collection="excludeMaterialIdList" item="id" open="(" separator="," close=")">#{id}</foreach></if>
        <if test="includeMaterialIdList != null and includeMaterialIdList.size() > 0"> and m.id in <foreach collection="includeMaterialIdList" item="id" open="(" separator="," close=")">#{id}</foreach></if>
    </select>

    <select id="selectFdMaterialById" parameterType="Long" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where m.id = #{id} and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{scopedTenantId}
    </select>

    <select id="selectFdMaterialByIds" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{scopedTenantId}
        and m.id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="selectFdMaterialByIdAndTenant" resultMap="FdMaterialResult">
        <include refid="selectFdMaterialVo"/>
        where m.id = #{id} and (m.del_flag = 0 or m.del_flag is null)
        <if test="tenantId != null and tenantId != ''">
            and m.tenant_id = #{tenantId}
        </if>
    </select>
    <select id="selectFdMaterialByCode" parameterType="String" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where m.code = #{code} and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{scopedTenantId}
    </select>
    <select id="selectFdMaterialByHisId" parameterType="String" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where m.his_id = #{hisId} and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{scopedTenantId} limit 1
    </select>

    <select id="selectFdMaterialByTenantAndHisId" resultMap="FdMaterialResult">
        <include refid="selectFdMaterialVo"/>
        where m.his_id = #{hisId} and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{tenantId}
        limit 1
    </select>
    <select id="selectFdMaterialByTenantAndHisChargeItemId" resultMap="FdMaterialResult">
        <include refid="selectFdMaterialVo"/>
        where trim(m.his_charge_item_id) = trim(#{hisChargeItemId})
          and (m.del_flag = 0 or m.del_flag is null)
          and m.tenant_id = #{tenantId}
        limit 1
    </select>
    <select id="countHighValueMaterialByChargeItemId" resultType="int">
        select count(1) from fd_material m
        where trim(m.his_charge_item_id) = trim(#{hisChargeItemId})
          and (m.del_flag = 0 or m.del_flag is null)
          and m.tenant_id = #{tenantId}
          and trim(m.is_gz) = '1'
    </select>

    <select id="selectFdMaterialByTenantAndCode" resultMap="FdMaterialResult">
        <include refid="selectFdMaterialVo"/>
        where m.code = #{code} and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{tenantId}
        limit 1
    </select>
    <!-- 根据主条码(udi_no)或耗材编码查询产品档案，用于入库扫码带出产品 -->
    <select id="selectFdMaterialByMainBarcode" parameterType="String" resultMap="FdMaterialResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <include refid="selectFdMaterialVo"/>
        where (m.udi_no = #{mainBarcode} or m.code = #{mainBarcode}) and (m.del_flag = 0 or m.del_flag is null) and m.tenant_id = #{scopedTenantId} limit 1
    </select>
    <insert id="insertFdMaterial" parameterType="FdMaterial" useGeneratedKeys="true" keyProperty="id">
        <bind name="tenantCtxCustomerId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        <bind name="insertTenantId" value="tenantId != null and tenantId != '' ? tenantId : (tenantCtxCustomerId != null ? tenantCtxCustomerId : @com.spd.common.utils.TenantContext@getTenantId())" />
        insert into fd_material
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">code,</if>
            <if test="name != null">name,</if>
            <if test="hisId != null and hisId != ''">his_id,</if>
            <if test="hisChargeItemId != null and hisChargeItemId != ''">his_charge_item_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="speci != null">speci,</if>
            <if test="model != null">model,</if>
            <if test="price != null">price,</if>
            <if test="defaultWarehouseId != null">default_warehouse_id,</if>
            <if test="referredName != null">referred_name,</if>
            <if test="useName != null">use_name,</if>
            <if test="factoryId != null">factory_id,</if>
            <if test="storeroomId != null">storeroom_id,</if>
            <if test="materialCategoryId != null and materialCategoryId != ''">material_category_id,</if>
            <if test="financeCategoryId != null">finance_category_id,</if>
            <if test="unitId != null">unit_id,</if>
            <if test="registerName != null">register_name,</if>
            <if test="registerNo != null">register_no,</if>
            <if test="medicalName != null">medical_name,</if>
            <if test="medicalNo != null">medical_no,</if>
            <if test="periodDate != null">period_date,</if>
            <if test="successfulType != null">successful_type,</if>
            <if test="successfulNo != null">successful_no,</if>
            <if test="successfulPrice != null">successful_price,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="packageSpeci != null">package_speci,</if>
            <if test="minPackageQty != null">min_package_qty,</if>
            <if test="producer != null">producer,</if>
            <if test="materialLevel != null">material_level,</if>
            <if test="registerLevel != null">register_level,</if>
            <if test="riskLevel != null">risk_level,</if>
            <if test="firstaidLevel != null">firstaid_level,</if>
            <if test="doctorLevel != null">doctor_level,</if>
            <if test="brand != null">brand,</if>
            <if test="useto != null">useto,</if>
            <if test="quality != null">quality,</if>
            <if test="function != null">`function`,</if>
            <if test="isWay != null">is_way,</if>
            <if test="udiNo != null">udi_no,</if>
            <if test="permitNo != null">permit_no,</if>
            <if test="countryNo != null">country_no,</if>
            <if test="countryName != null">country_name,</if>
            <if test="description != null">description,</if>
            <if test="isUse != null">is_use,</if>
            <if test="isProcure != null">is_procure,</if>
            <if test="isMonitor != null">is_monitor,</if>
            <if test="isTemporaryPurchase != null">is_temporary_purchase,</if>
            <if test="isServiceFee != null">is_service_fee,</if>
