<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spd.foundation.mapper.FdDepartmentMapper">

    <resultMap type="FdDepartment" id="FdDepartmentResult">
        <result property="id"    column="id"    />
        <result property="code"    column="code"    />
        <result property="name"    column="name"    />
        <result property="referredName"    column="referred_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="tenantId"    column="tenant_id"    />
        <result property="parentId"    column="parent_id"    />
        <result property="deptRemark"    column="remark"    />
        <result property="thirdPartyDeptId"    column="third_party_dept_id"    />
    </resultMap>

    <sql id="selectFdDepartmentVo">
        select id, code, name, referred_name, remark, third_party_dept_id, del_flag, create_by, create_time, update_by, update_time, tenant_id, parent_id from fd_department
    </sql>

    <select id="selectFdDepartmentList" parameterType="FdDepartment" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        <include refid="selectFdDepartmentVo"/>
        where del_flag != 1
        and tenant_id = #{tenantId}
        <if test="code != null  and code != ''"> and code = #{code}</if>
        <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        <if test="referredName != null and referredName != ''"> and referred_name like concat('%', #{referredName}, '%')</if>
        <if test="deptRemark != null and deptRemark != ''"> and remark like concat('%', #{deptRemark}, '%')</if>
        <if test="treeParentId != null"> and parent_id = #{treeParentId}</if>
        <if test="params != null and params.allowedDeptIds != null">
            <choose>
                <when test="params.allowedDeptIds.size() > 0"> and id in <foreach collection="params.allowedDeptIds" item="id" open="(" separator="," close=")">#{id}</foreach></when>
                <otherwise> and 1=0</otherwise>
            </choose>
        </if>
    </select>

    <select id="selectFdDepartmentById" parameterType="String" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        <include refid="selectFdDepartmentVo"/>
        where id = #{id} and tenant_id = #{tenantId}
    </select>

    <!-- 按编码+租户查一条（导入去重；平台 tenantId 为空时匹配 tenant_id 为空） -->
    <select id="selectFdDepartmentByCodeAndTenantId" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        <include refid="selectFdDepartmentVo"/>
        where del_flag != 1 and code = #{code} and tenant_id = #{tenantId}
        limit 1
    </select>

    <select id="selectdepartmenAll" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        <include refid="selectFdDepartmentVo"/>
        where del_flag != 1 and tenant_id = #{tenantId}
    </select>

    <select id="selectdepartmenAllByTenantId" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        <include refid="selectFdDepartmentVo"/>
        where del_flag != 1 and tenant_id = #{tenantId}
    </select>

    <select id="selectDepartmenListByUserId" parameterType="Long" resultType="Long">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        select d.id
        from fd_department d
        left join sys_user_department ud on ud.department_id = d.id
        left join sys_user u on u.user_id = ud.user_id
        where d.del_flag != 1 and d.tenant_id = #{tenantId}
        <if test="userId != null  and userId != 0"> and u.user_id = #{userId}</if>
    </select>

    <select id="countChildrenByParentId" resultType="int">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        select count(*) from fd_department where del_flag != 1 and parent_id = #{parentId} and tenant_id = #{tenantId}
    </select>

    <select id="selectUserDepartmenAll" parameterType="Long" resultMap="FdDepartmentResult">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        select d.id,d.code,d.name
        from fd_department d
        left join sys_user_department ud on ud.department_id = d.id
        left join sys_user u on u.user_id = ud.user_id
        where d.del_flag != 1 and d.tenant_id = #{tenantId}
        <if test="userId != null  and userId != 0"> and u.user_id = #{userId}</if>
    </select>

    <insert id="insertFdDepartment" parameterType="FdDepartment">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        insert into fd_department
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="code != null and code != ''">code,</if>
            <if test="name != null">name,</if>
            <if test="referredName != null">referred_name,</if>
            <if test="deptRemark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            tenant_id,
            <if test="parentId != null">parent_id,</if>
            <if test="thirdPartyDeptId != null and thirdPartyDeptId != ''">third_party_dept_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="code != null and code != ''">#{code},</if>
            <if test="name != null">#{name},</if>
            <if test="referredName != null">#{referredName},</if>
            <if test="deptRemark != null">#{deptRemark},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            #{tenantId},
            <if test="parentId != null">#{parentId},</if>
            <if test="thirdPartyDeptId != null and thirdPartyDeptId != ''">#{thirdPartyDeptId},</if>
         </trim>
    </insert>

    <update id="updateFdDepartment" parameterType="FdDepartment">
        <bind name="tenantId" value="@com.spd.common.utils.SecurityUtils@getCustomerId()" />
        update fd_department
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="name != null">name = #{name},</if>
            <if test="referredName != null">referred_name = #{referredName},</if>
            <if test="deptRemark != null">remark = #{deptRemark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            parent_id = #{parentId,jdbcType=BIGINT},
            <choose>
                <when test="params != null and params.skipThirdPartyDeptId == true"></when>
                <otherwise>
                    <if test="thirdPartyDeptId != null">third_party_dept_id = #{thirdPartyDeptId},</if>
                </otherwise>
            </choose>
        </trim>
        where id = #{id} and tenant_id = #{tenantId}
    </update>

