    <select id="selectStkProfitLossPendingById" resultMap="StkProfitLossPendingResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        select id, bill_id, entry_id, warehouse_id, department_id, material_id, supplier_id,
               batch_no, batch_id, batch_number, qty, unit_price, amt, begin_time, end_time,
               main_barcode, sub_barcode, apply_status, settlement_effect_status, tenant_id,
               del_flag, delete_by, delete_time, create_by, create_time, update_by, update_time
        from stk_profit_loss_pending
        where id = #{id}
          and tenant_id = #{scopedTenantId}
          and (del_flag = 0 or del_flag is null)
        limit 1
    </select>

    <select id="selectStkProfitLossPendingList" parameterType="com.spd.warehouse.domain.StkProfitLossPending" resultMap="StkProfitLossPendingResult">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        select id, bill_id, entry_id, warehouse_id, department_id, material_id, supplier_id,
               batch_no, batch_id, batch_number, qty, unit_price, amt, begin_time, end_time,
               main_barcode, sub_barcode, apply_status, settlement_effect_status, tenant_id,
               del_flag, delete_by, delete_time, create_by, create_time, update_by, update_time
        from stk_profit_loss_pending
        <where>
            tenant_id = #{scopedTenantId}
            and (del_flag = 0 or del_flag is null)
            <if test="id != null">and id = #{id}</if>
            <if test="billId != null">and bill_id = #{billId}</if>
            <if test="entryId != null">and entry_id = #{entryId}</if>
            <if test="warehouseId != null">and warehouse_id = #{warehouseId}</if>
            <if test="materialId != null">and material_id = #{materialId}</if>
            <if test="batchNo != null and batchNo != ''">and batch_no like concat('%', #{batchNo}, '%')</if>
            <if test="applyStatus != null and applyStatus != ''">and apply_status = #{applyStatus}</if>
            <if test="settlementEffectStatus != null and settlementEffectStatus != ''">and settlement_effect_status = #{settlementEffectStatus}</if>
        </where>
        order by id desc
    </select>

    <update id="updatePendingStatusById">
        <bind name="scopedTenantId" value="@com.spd.common.utils.SecurityUtils@requiredScopedTenantIdForSql()" />
        update stk_profit_loss_pending
        set apply_status = #{applyStatus},
            settlement_effect_status = #{settlementEffectStatus},
            update_by = #{updateBy},
            update_time = now()
        where id = #{id}
          and tenant_id = #{scopedTenantId}
          and (del_flag = 0 or del_flag is null)
    </update>

